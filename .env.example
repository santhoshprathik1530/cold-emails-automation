# ── Cold Email Hub — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# You can also set these in the app's Settings tab.

# Apollo API
APOLLO_API_KEY=your_apollo_api_key_here

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Tracking server URL (must be publicly accessible for email opens to track)
# For local testing: http://localhost:8000
# For production: use ngrok (https://ngrok.com) or deploy to Railway/Fly.io
TRACKING_URL=http://localhost:8000

# Your personal info (used in email templates)
SENDER_NAME=Your Full Name
RESUME_URL=https://yoursite.com/resume.pdf
LINKEDIN_URL=https://linkedin.com/in/yourhandle
WEBSITE_URL=https://yourportfolio.com

# App login (protects enrichment, send, and settings)
APP_USERNAME=your_username
APP_PASSWORD=your_password

# ── Streamlit Cloud Deployment ───────────────────────────────────────────────
# gmail_credentials.json cannot be committed to the repo.
# Instead, authenticate locally once, then copy the contents of .gmail_token.json
# and add it to your Streamlit Cloud app secrets as:
#
#   gmail_token_json = '{"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","token_uri":"https://oauth2.googleapis.com/token","scopes":["..."]}'
#
# The app will automatically load it from secrets when the token file is not present.
